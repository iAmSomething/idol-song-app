{
  "expo": {
    "name": "Idol Song App",
    "slug": "idol-song-app-mobile",
    "version": "0.1.0",
    "scheme": "idolsongapp",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
