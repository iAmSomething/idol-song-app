APP_ENV=preview

# Temporary fallback only when the stable public preview backend is unavailable.
# Replace with your own cloudflared/ngrok HTTPS tunnel URL.
EXPO_PUBLIC_API_BASE_URL=https://preview-tunnel.example.trycloudflare.com
EXPO_PUBLIC_EXPO_PROJECT_ID=

# Optional metadata
EXPO_PUBLIC_BUILD_VERSION=
EXPO_PUBLIC_DATASET_VERSION=
EXPO_PUBLIC_COMMIT_SHA=

# Optional service credentials
EXPO_PUBLIC_ANALYTICS_WRITE_KEY=

# Optional feature-gate overrides
EXPO_PUBLIC_ENABLE_RADAR=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_REMOTE_REFRESH=false
EXPO_PUBLIC_ENABLE_MV_EMBED=true
EXPO_PUBLIC_ENABLE_SHARE_ACTIONS=true
