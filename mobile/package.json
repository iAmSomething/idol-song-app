{
  "name": "idol-song-app-mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:development": "cross-env APP_ENV=development expo start",
    "start:preview": "cross-env APP_ENV=preview expo start",
    "start:production": "cross-env APP_ENV=production expo start",
    "qa:preview:ios:prebuild": "cross-env APP_ENV=preview expo prebuild --platform ios --no-install --clean",
    "qa:preview:ios:sim": "cross-env APP_ENV=preview expo run:ios --device \"iPhone 16e\" --port 8082",
    "qa:preview:ios:signing:prepare": "bash ./scripts/prepare-ios-preview-signing.sh",
    "qa:preview:ios:voiceover:on": "bash ./scripts/toggle-ios-simulator-voiceover.sh on",
    "qa:preview:ios:voiceover:off": "bash ./scripts/toggle-ios-simulator-voiceover.sh off",
    "ios:production:signing:prepare": "bash ./scripts/prepare-ios-production-signing.sh",
    "ios:production:install": "bash ./scripts/install-ios-production.sh",
    "ios:production:archive": "bash ./scripts/archive-ios-production.sh",
    "qa:preview:android:prebuild": "cross-env APP_ENV=preview expo prebuild --platform android --no-install --clean",
    "qa:preview:android:avd:prepare": "bash ./scripts/prepare-android-preview-qa-emulator.sh",
    "qa:preview:android:avd:launch": "bash ./scripts/prepare-android-preview-qa-emulator.sh --launch",
    "qa:preview:android:emu": "cross-env APP_ENV=preview expo run:android --port 8083",
    "android:production:assemble": "cross-env APP_ENV=production EXPO_PUBLIC_API_BASE_URL=https://idol-song-app-production.up.railway.app bash -lc 'cd android && ./gradlew assembleRelease'",
    "android:production:bundle": "cross-env APP_ENV=production EXPO_PUBLIC_API_BASE_URL=https://idol-song-app-production.up.railway.app bash -lc 'cd android && ./gradlew bundleRelease'",
    "android:production:distribute": "bash ./scripts/distribute-android-production.sh",
    "android:production:distribute:dry-run": "bash ./scripts/distribute-android-production.sh --dry-run",
    "android": "expo run:android",
    "ios": "npm run ios:production:install --",
    "ios:signing:prepare": "npm run ios:production:signing:prepare --",
    "ios:archive": "npm run ios:production:archive --",
    "ios:dev": "expo run:ios",
    "ios:preview": "npm run qa:preview:ios:sim --",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:qa:ui": "jest --runInBand src/components/calendar/DayCell.test.tsx src/components/calendar/DateDetailSheet.test.tsx src/components/layout/BottomSheetFrame.test.tsx src/components/layout/SummaryStrip.test.tsx src/components/feedback/FeedbackState.test.tsx src/components/actions/ServiceButton.test.tsx src/components/actions/ServiceButtonGroup.test.tsx src/components/identity/TeamIdentityRow.test.tsx src/components/release/TrackRow.test.tsx src/components/surfaces/SurfacePrimitives.test.tsx",
    "test:qa:functional": "jest --runInBand src/features/calendarControls.test.tsx src/features/calendarBottomSheet.test.tsx src/features/searchTab.test.tsx src/features/searchTabLoading.test.tsx src/features/radarTab.test.tsx src/features/entityDetailScreen.test.tsx src/features/releaseDetailScreen.test.tsx src/features/route-shell.smoke.test.tsx",
    "test:qa:server": "jest --runInBand src/config/runtime.test.ts src/services/backendReadClient.test.ts src/services/backendDisplayAdapters.test.ts src/services/datasetFailurePolicy.test.ts src/services/screenSnapshotCache.test.ts src/features/useActiveDatasetScreen.test.tsx src/selectors/index.test.ts src/selectors/specParity.test.ts",
    "verify:qa:platforms": "cross-env EXPO_PUBLIC_API_BASE_URL=https://api.idol-song-app.example.com npm run config:preview && cross-env EXPO_PUBLIC_API_BASE_URL=https://api.idol-song-app.example.com npm run config:production && cross-env APP_ENV=preview EXPO_PUBLIC_API_BASE_URL=https://api.idol-song-app.example.com expo export --platform ios --output-dir /tmp/idol-song-app-mobile-export-ios >/dev/null && cross-env APP_ENV=preview EXPO_PUBLIC_API_BASE_URL=https://api.idol-song-app.example.com expo export --platform android --output-dir /tmp/idol-song-app-mobile-export-android >/dev/null",
    "verify:qa:full": "npm run test:qa:ui && npm run test:qa:functional && npm run test:qa:server && npm run typecheck && npm run lint && npm run verify:qa:platforms",
    "verify:runtime-policy": "jest --runInBand src/config/runtime.test.ts src/services/datasetFailurePolicy.test.ts src/features/useActiveDatasetScreen.test.tsx",
    "verify:firebase:android": "node ./scripts/verify-android-firebase-config.mjs",
    "config:development": "cross-env APP_ENV=development expo config --json",
    "config:preview": "cross-env APP_ENV=preview expo config --json",
    "config:production": "cross-env APP_ENV=production expo config --json"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.13",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.2",
    "@react-native-community/cli-platform-android": "^20.1.2",
    "@react-native-community/cli-platform-ios": "^20.1.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "^55.0.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  }
}
